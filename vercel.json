{
  "version": 2,
  "buildCommand": "echo 'Static build'",
  "outputDirectory": "./",
  "public": true,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/pokemon-tactical-cheatsheet.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    }
  ]
}
